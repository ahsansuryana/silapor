# ─────────────────────────────────────────
# SILAPOR - Backend Environment (template)
# ─────────────────────────────────────────
# Copy this file:  cp backend/.env.example backend/.env
# Lalu isi nilainya.

# ─── Database (PostgreSQL) ───
DB_HOST=
DB_PORT=5432
DB_USER=
DB_PASSWORD=
DB_NAME=silapor_db

# ─── Object Storage (MinIO) ───
MINIO_ENDPOINT=
MINIO_PORT=9000
MINIO_USER=minioadmin
MINIO_PASSWORD=
MINIO_BUCKET=silapor

# ─── JWT ───
ACCESS_TOKEN_SECRET=
REFRESH_TOKEN_SECRET=
ACCESS_TOKEN_EXPIRES=15m
REFRESH_TOKEN_EXPIRES=7d

# ─── Google OAuth ───
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://backend-silapor.nuxantara.site/api/auth/google/callback

# ─── URLs ───
CLIENT_URL=https://silapor.nuxantara.site
FRONTEND_URL=https://silapor.nuxantara.site

# ─── Firebase Admin SDK ───
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
