# ─────────────────────────────────────────
# SILAPOR - Frontend Environment (template)
# ─────────────────────────────────────────
# Copy this file:  cp frontend/.env.example frontend/.env
#
# Catatan:
# Pas production (docker compose build), VITE_* diisi via build args
# dari root .env. File ini cuma buat development lokal.

VITE_BASE_URL=http://localhost:5173
VITE_API_BACKEND_URL=http://localhost:3000

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_VAPID_KEY=
